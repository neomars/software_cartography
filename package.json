{
  "name": "logiciel-3d-viz",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "concurrently \"npm run start:server\" \"npm run start:client\"",
    "start:server": "npm run start --workspace=server",
    "start:client": "npm run start --workspace=client",
    "install:all": "npm install"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}
